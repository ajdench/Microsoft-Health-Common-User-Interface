---
const { head } = Astro.locals.starlightRoute;
---

{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}

<style is:global>
  .sl-markdown-content .sl-heading-wrapper {
    --sl-anchor-icon-size: 20px;
    --msh-anchor-shift: 0px;
  }

  .sl-markdown-content .sl-anchor-link {
    color: color-mix(in srgb, var(--page-text-secondary) 56%, white 44%) !important;
  }

  .sl-markdown-content .sl-anchor-icon > svg {
    display: inline;
    width: var(--sl-anchor-icon-size);
    vertical-align: top;
    transform: translateY(
      calc(
        (var(--sl-line-height-headings) * 1em - var(--sl-anchor-icon-size)) / 2 +
          var(--msh-anchor-shift)
      )
    );
  }
</style>

<script is:inline>
  (() => {
    const normalizeText = (value) => value?.replace(/\s+/g, ' ').trim() ?? '';
    const descenderPattern = /[gjpqyQ,;:]/g;
    const metricCanvas = document.createElement('canvas');
    const metricContext = metricCanvas.getContext('2d');

    const buildCanvasFont = (style) =>
      [
        style.fontStyle,
        style.fontVariant,
        style.fontWeight,
        style.fontStretch,
        style.fontSize,
        style.fontFamily,
      ]
        .filter(Boolean)
        .join(' ');

    const applyHeadingAnchorAlignment = () => {
      if (!metricContext) return;

      document.querySelectorAll('.sl-markdown-content .sl-heading-wrapper').forEach((wrapper) => {
        const heading = wrapper.querySelector(':scope > h1, :scope > h2, :scope > h3, :scope > h4, :scope > h5, :scope > h6');
        const svg = wrapper.querySelector(':scope > .sl-anchor-link .sl-anchor-icon > svg');

        if (!heading || !svg) return;

        const headingText = normalizeText(heading.textContent);
        if (!headingText) return;

        const textStyle = getComputedStyle(heading);
        const wrapperRect = wrapper.getBoundingClientRect();
        const svgRect = svg.getBoundingClientRect();
        const lineHeight = parseFloat(getComputedStyle(wrapper).lineHeight) || wrapperRect.height;

        metricContext.font = buildCanvasFont(textStyle);

        const fullMetrics = metricContext.measureText(headingText);
        const descenderlessMetrics = metricContext.measureText(
          headingText.replace(descenderPattern, 'x')
        );

        const ascent = fullMetrics.actualBoundingBoxAscent || 0;
        const descent = fullMetrics.actualBoundingBoxDescent || 0;
        const descenderlessDescent = descenderlessMetrics.actualBoundingBoxDescent || 0;
        const textHeight = ascent + descent;
        const leading = Math.max(0, lineHeight - textHeight);
        const baselineY = wrapperRect.top + leading / 2 + ascent;

        const topGuide = baselineY + descenderlessDescent;
        const bottomGuide = baselineY + descent;
        const targetCenter = (topGuide + bottomGuide) / 2;
        const currentCenter = (svgRect.top + svgRect.bottom) / 2;
        const shift = targetCenter - currentCenter;

        wrapper.style.setProperty('--msh-anchor-shift', `${shift.toFixed(2)}px`);
      });
    };

    const getNavBucket = (pathname) => {
      if (pathname.startsWith('/derived/inventories/')) return 'Inventories';
      if (
        pathname.startsWith('/wiki/source-notes/') ||
        pathname.startsWith('/raw/metadata/') ||
        pathname.startsWith('/raw/manifests/')
      ) {
        return 'Sources';
      }
      if (pathname.startsWith('/wiki/overview/')) return 'Overview';
      return 'Wiki';
    };

    const applyHeaderNavState = () => {
      const activeBucket = getNavBucket(window.location.pathname);

      document.querySelectorAll('.page-nav-link').forEach((element) => {
        const label = element.textContent?.trim() ?? '';
        element.classList.toggle('active', label === activeBucket);
      });
    };

    const getTocPageTitle = () => normalizeText(document.querySelector('main h1')?.textContent) || 'Overview';

    const applyTocPageTitleLabel = () => {
      const topLabel = getTocPageTitle();

      document.querySelectorAll('.page-toc-sticky nav').forEach((nav) => {
        let title = nav.querySelector(':scope > .msh-toc-page-title');
        if (!title) {
          title = document.createElement('div');
          title.className = 'msh-toc-page-title';
          const heading = nav.querySelector(':scope > h2');
          if (heading) {
            heading.insertAdjacentElement('afterend', title);
          } else {
            nav.prepend(title);
          }
        }
        title.textContent = topLabel;

        const mobileTitle = nav.querySelector(':scope > details > .dropdown > .msh-toc-page-title');
        const dropdown = nav.querySelector(':scope > details > .dropdown');
        if (dropdown && !mobileTitle) {
          const titleNode = document.createElement('div');
          titleNode.className = 'msh-toc-page-title msh-toc-page-title-mobile';
          titleNode.textContent = topLabel;
          dropdown.prepend(titleNode);
        } else if (mobileTitle) {
          mobileTitle.textContent = topLabel;
        }
      });
    };

    const applyTocHashSelection = () => {
      const hash = window.location.hash;
      if (!hash) return;

      document.querySelectorAll('.page-toc-sticky nav').forEach((nav) => {
        const links = Array.from(nav.querySelectorAll('a[href^="#"]'));
        const selected = links.find((link) => (link.getAttribute('href') ?? '') === hash);
        if (!selected) return;

        links.forEach((link) => {
          if (link === selected) {
            link.setAttribute('aria-current', 'true');
          } else {
            link.removeAttribute('aria-current');
          }
        });
      });
    };

    const applyTocOverflowState = () => {
      document.querySelectorAll('.page-toc-sticky').forEach((element) => {
        const hasOverflow = element.scrollHeight > element.clientHeight + 1;
        element.classList.toggle('toc-has-scrollbar', hasOverflow);
      });
    };

    const scheduleApply = () =>
      requestAnimationFrame(() =>
        requestAnimationFrame(() => {
          applyHeaderNavState();
          applyHeadingAnchorAlignment();
          applyTocPageTitleLabel();
          applyTocHashSelection();
          applyTocOverflowState();
        })
      );

    const bindObservers = () => {
      scheduleApply();

      if (window.__mshTocResizeObserver) {
        window.__mshTocResizeObserver.disconnect();
      }

      const resizeObserver = new ResizeObserver(() => applyTocOverflowState());
      document.querySelectorAll('.page-toc-sticky').forEach((element) => resizeObserver.observe(element));
      window.__mshTocResizeObserver = resizeObserver;
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bindObservers, { once: true });
    } else {
      bindObservers();
    }

    document.fonts?.ready?.then(() => applyHeadingAnchorAlignment());

    document.addEventListener('astro:page-load', scheduleApply);
    window.addEventListener('resize', () => {
      applyHeaderNavState();
      applyHeadingAnchorAlignment();
      applyTocPageTitleLabel();
      applyTocHashSelection();
      applyTocOverflowState();
    }, { passive: true });
    window.addEventListener('hashchange', scheduleApply);
    window.addEventListener('pageshow', bindObservers);
  })();
</script>
