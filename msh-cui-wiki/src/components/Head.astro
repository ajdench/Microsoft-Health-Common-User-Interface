---
const { head } = Astro.locals.starlightRoute;
---

{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}

<script is:inline>
  (() => {
    const isIndexPage = (pathname) => pathname === '/' || pathname === '/index' || pathname === '/index/';
    const normalizeText = (value) => value?.replace(/\s+/g, ' ').trim() ?? '';

    const getNavBucket = (pathname) => {
      if (pathname.startsWith('/derived/inventories/')) return 'Inventories';
      if (
        pathname.startsWith('/wiki/source-notes/') ||
        pathname.startsWith('/raw/metadata/') ||
        pathname.startsWith('/raw/manifests/')
      ) {
        return 'Sources';
      }
      if (pathname.startsWith('/wiki/overview/')) return 'Overview';
      return 'Wiki';
    };

    const applyHeaderNavState = () => {
      const activeBucket = getNavBucket(window.location.pathname);

      document.querySelectorAll('.page-nav-link').forEach((element) => {
        const label = element.textContent?.trim() ?? '';
        element.classList.toggle('active', label === activeBucket);
      });
    };

    const getTocPageTitle = () => normalizeText(document.querySelector('main h1')?.textContent) || 'Overview';

    const applyTocTitleState = () => {
      const topHref = isIndexPage(window.location.pathname) ? '/index' : window.location.pathname;
      const topLabel = getTocPageTitle();

      document.querySelectorAll('.page-toc-sticky nav > ul').forEach((list) => {
        const items = Array.from(list.children).filter((element) => element.tagName === 'LI');
        if (items.length === 0) return;

        const [topItem, ...directChildren] = items;
        const topLink = topItem.querySelector(':scope > a');
        if (!topLink) return;

        const nestedList = topItem.querySelector(':scope > ul');
        const nestedChildren = nestedList
          ? Array.from(nestedList.children).filter((element) => element.tagName === 'LI')
          : [];
        const childItems = [...directChildren, ...nestedChildren];

        if (nestedList) {
          nestedList.remove();
        }

        topLink.setAttribute('href', topHref);
        const topSpan = topLink.querySelector('span');
        if (topSpan) {
          topSpan.textContent = topLabel;
          topSpan.style.setProperty('--depth', '0');
        } else {
          topLink.textContent = topLabel;
        }
        topItem.style.setProperty('--depth', '0');
        topItem.querySelectorAll(':scope > a, :scope > a > span').forEach((element) => {
          element.style.setProperty('--depth', '0');
        });

        if (childItems.length === 0) {
          return;
        }

        const nextNestedList = document.createElement('ul');
        nextNestedList.className = list.className;
        nextNestedList.style.setProperty('--depth', '1');
        topItem.appendChild(nextNestedList);

        childItems.forEach((item) => {
          item.style.setProperty('--depth', '1');
          item.querySelectorAll(':scope > a, :scope > a > span').forEach((element) => {
            element.style.setProperty('--depth', '1');
          });
          nextNestedList.appendChild(item);
        });
      });
    };

    const applyTocSelectionState = () => {
      const hash = window.location.hash;

      document.querySelectorAll('.page-toc-sticky nav > ul > li').forEach((topItem) => {
        const topLink = topItem.querySelector(':scope > a');
        if (!topLink) return;

        const childLinks = Array.from(topItem.querySelectorAll(':scope > ul a[href]'));
        const hasHashSelectedChild =
          Boolean(hash) && childLinks.some((link) => (link.getAttribute('href') ?? '').endsWith(hash));

        if (hasHashSelectedChild) {
          topLink.removeAttribute('aria-current');
          topLink.setAttribute('data-msh-parent-context', 'true');
          return;
        }

        topLink.setAttribute('aria-current', 'true');
        topLink.removeAttribute('data-msh-parent-context');
      });
    };

    const applyTocOverflowState = () => {
      document.querySelectorAll('.page-toc-sticky').forEach((element) => {
        const hasOverflow = element.scrollHeight > element.clientHeight + 1;
        element.classList.toggle('toc-has-scrollbar', hasOverflow);
      });
    };

    const scheduleApply = () =>
      requestAnimationFrame(() =>
        requestAnimationFrame(() => {
          applyHeaderNavState();
          applyTocTitleState();
          applyTocSelectionState();
          applyTocOverflowState();
        })
      );

    const bindObservers = () => {
      scheduleApply();

      if (window.__mshTocResizeObserver) {
        window.__mshTocResizeObserver.disconnect();
      }

      const resizeObserver = new ResizeObserver(() => applyTocOverflowState());
      document.querySelectorAll('.page-toc-sticky').forEach((element) => resizeObserver.observe(element));
      window.__mshTocResizeObserver = resizeObserver;
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bindObservers, { once: true });
    } else {
      bindObservers();
    }

    document.addEventListener('astro:page-load', scheduleApply);
    window.addEventListener('resize', () => {
      applyHeaderNavState();
      applyTocTitleState();
      applyTocOverflowState();
    }, { passive: true });
    window.addEventListener('pageshow', bindObservers);
  })();
</script>
